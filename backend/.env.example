# --- BE Deployment Configuration Template ---

# [Mandatory] Mistral AI Client Key for Roadmap & Project Generation
MISTRAL_API_KEY=your_mistral_api_key_here

# [Optional] Allowed CORS origins. Comma-separated list (e.g. https://yourfrontend.com) or "*" to allow all
ALLOWED_ORIGINS=*

# [Optional] Server host address and port uvicorn should bind to
HOST=0.0.0.0
PORT=8000
